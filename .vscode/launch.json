{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Backend: Debug",
            "type": "debugpy",
            "request": "launch",
            "module": "mcpapps_bridge.debug_main",
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend/src"
            },
            "python": "${workspaceFolder}/backend/.venv/bin/python",
            "console": "integratedTerminal"
        }
    ]
}