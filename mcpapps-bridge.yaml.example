bridge:
  apiHost: 127.0.0.1
  apiPort: 8765
  # proxyName: enterprise-ops-hub  # uncomment to set a fixed downstream name
  # httpxTimeoutSeconds: 30  # HTTP request timeout in seconds (default: 30)

storage:
  profile: sqlite
  sqlitePath: ./backend/var/mcpapps-bridge.db
  autoMigrate: true
  bootstrapMode: seed-if-empty

endpoints:
  test-endpoint:
    displayName: Test Endpoint
    mode: passthrough
    bindings:
      - upstream: enterprise-ops-hub-http-1

upstreams:
  enterprise-ops-hub-http-1:
    transport: streamable-http
    url: http://localhost:8760/mcp
    # headers: {}

  enterprise-ops-hub-http-2:
    transport: streamable-http
    url: http://localhost:8759/mcp
    # headers: {}
